# Database connection
DATABASE_URL=postgresql+asyncpg://app_user:app_password@localhost:5432/app_db

# Buffer settings (near real-time)
BUFFER_MAX_SIZE=100
BUFFER_MAX_SECONDS=2.0

# API settings
API_PREFIX=/api/v1

# Authentication (comma-separated list of valid API keys)
API_KEYS=dev-key-change-me,another-key
